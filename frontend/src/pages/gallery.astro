---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/GalleryGrid.jsx';
---

<Layout title="Галерея" description="Фотографии работ мастера маникюра GLAM nails">
  <section class="page-header">
    <div class="container">
      <h1>Галерея работ</h1>
      <p>Наши лучшие работы и идеи для вашего вдохновения</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <GalleryGrid client:load />
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <h2>Хотите такой же маникюр?</h2>
      <p>Запишитесь на приём и воплотим ваши идеи в жизнь!</p>
      <a href="/booking" class="btn btn-primary">Записаться онлайн</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 140px 24px 60px;
    background: linear-gradient(135deg, var(--color-bg) 0%, #FFE4EF 100%);
    text-align: center;
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--color-primary-dark);
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  .cta-section {
    background: linear-gradient(135deg, var(--color-primary-dark), #C4177A);
    text-align: center;
    color: white;
  }

  .cta-section h2 {
    color: white;
    font-size: 2.2rem;
    margin-bottom: 12px;
  }

  .cta-section p {
    font-size: 1rem;
    margin-bottom: 24px;
    opacity: 0.9;
  }

  .cta-section .btn-primary {
    background: white;
    color: var(--color-primary-dark);
  }
</style>
