---
import Layout from '../layouts/Layout.astro';

// Получаем услуги из API на build-time
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';

let priceList: { category: string; services: any[] }[] = [];
try {
  const res = await fetch(`${API_URL}/api/services/grouped`);
  if (res.ok) {
    const grouped = await res.json();
    priceList = Object.entries(grouped).map(([category, services]) => ({
      category,
      services
    }));
  }
} catch (e) {
  console.warn('Failed to fetch services from API');
}
---

<Layout title="Прайс-лист" description="Актуальные цены на услуги маникюрного салона GLAM nails">
  <section class="page-header">
    <div class="container">
      <h1>Прайс-лист</h1>
      <p>Прозрачные цены без скрытых доплат</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="price-tables">
        {priceList.length > 0 ? (
          priceList.map((item, index) => (
            <div class="price-table-section fade-in" style={`animation-delay: ${index * 0.1}s`}>
              <h2 class="table-title">{item.category}</h2>
              <div class="price-table">
                {item.services.map((service) => (
                  <div class="price-row">
                    <div class="price-details">
                      <span class="service-name">{service.name}</span>
                      <span class="service-duration">{service.duration} мин</span>
                    </div>
                    <span class="service-price">{service.price} ₽</span>
                  </div>
                ))}
              </div>
            </div>
          ))
        ) : (
          <div class="loading-fallback">Загрузка прайс-листа...</div>
        )}
      </div>
    </div>
  </section>

  <section class="section note-section">
    <div class="container">
      <div class="note">
        <p>💡 Указаны ориентировочные цены. Итоговая стоимость зависит от сложности работы и материалов.</p>
        <p>🎁 При первом посещении — скидка 10%!</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 140px 24px 60px;
    background: linear-gradient(135deg, var(--color-bg) 0%, #FFE4EF 100%);
    text-align: center;
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--color-primary-dark);
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  .price-tables {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .price-table-section {
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .table-title {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    padding: 20px 30px;
    font-size: 1.5rem;
  }

  .price-table {
    padding: 10px 0;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 30px;
    border-bottom: 1px solid rgba(255, 105, 180, 0.1);
    transition: background 0.3s ease;
  }

  .price-row:hover {
    background: var(--color-bg);
  }

  .price-row:last-child {
    border-bottom: none;
  }

  .price-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .service-name {
    font-weight: 500;
    color: var(--color-text);
  }

  .service-duration {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .service-price {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-gold);
  }

  .note-section {
    background: var(--color-bg);
  }

  .note {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .note p {
    margin-bottom: 12px;
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  .note p:last-child {
    margin-bottom: 0;
  }

  .loading-fallback {
    text-align: center;
    padding: 60px;
    color: var(--color-text-light);
  }
</style>
