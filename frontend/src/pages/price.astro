---
import Layout from '../layouts/Layout.astro';
import PriceList from '../components/PriceList.jsx';
---

<Layout title="Прайс-лист" description="Актуальные цены на услуги маникюрного салона GLAM nails">
  <section class="page-header">
    <div class="container">
      <h1>Прайс-лист</h1>
      <p>Прозрачные цены без скрытых доплат</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <PriceList client:load />
    </div>
  </section>

  <section class="section note-section">
    <div class="container">
      <div class="note">
        <p>💡 Указаны ориентировочные цены. Итоговая стоимость зависит от сложности работы и материалов.</p>
        <p>🎁 При первом посещении — скидка 10%!</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 140px 24px 60px;
    background: linear-gradient(135deg, var(--color-bg) 0%, #FFE4EF 100%);
    text-align: center;
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--color-primary-dark);
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  .note-section {
    background: var(--color-bg);
  }

  .note {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .note p {
    margin-bottom: 12px;
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  .note p:last-child {
    margin-bottom: 0;
  }
</style>
