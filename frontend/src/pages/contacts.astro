---
import Layout from '../layouts/Layout.astro';

const contacts = [
  { icon: "📍", title: "Адрес", value: "ул. Красивая, 15", sub: "Москва, Россия", type: "text" },
  { icon: "📞", title: "Телефон", value: "+79991234567", sub: "Звоните с 10:00 до 20:00", type: "tel" },
  { icon: "📧", title: "Email", value: "hello@glamnails.ru", sub: "Ответим в течение часа", type: "email" },
  { icon: "🕐", title: "Время работы", value: "10:00 - 20:00", sub: "Ежедневно", type: "text" }
];
---

<Layout title="Контакты" description="Контактная информация маникюрного салона GLAM nails">
  <section class="page-header">
    <div class="container">
      <h1>Контакты</h1>
      <p>Свяжитесь с нами любым удобным способом</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        {contacts.map((contact, index) => (
          <div class="contact-card fade-in" style={`animation-delay: ${index * 0.1}s`}>
            <div class="contact-icon">{contact.icon}</div>
            <h4>{contact.title}</h4>
            {contact.type === 'tel' ? (
              <p class="contact-value"><a href={`tel:${contact.value}`}>{contact.value}</a></p>
            ) : contact.type === 'email' ? (
              <p class="contact-value"><a href={`mailto:${contact.value}`}>{contact.value}</a></p>
            ) : (
              <p class="contact-value">{contact.value}</p>
            )}
            <p class="contact-sub">{contact.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section map-section">
    <div class="container">
      <!-- Замените координаты на реальные при деплое -->
      <iframe
        src="https://yandex.ru/map-widget/v1/?z=12&ol=biz&oid=0"
        width="100%"
        height="450"
        frameborder="0"
        allowfullscreen="true"
        style="border:0; border-radius: var(--radius-lg);"
        title="Карта расположения салона GLAM nails"
      ></iframe>
      <p class="map-note">📍 ул. Красивая, 15 — Москва</p>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <h2>Ждём вас в гости!</h2>
      <p>Запишитесь онлайн и мы подготовим всё для вашего визита</p>
      <a href="/booking" class="btn btn-primary">Записаться онлайн</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 140px 24px 60px;
    background: linear-gradient(135deg, var(--color-bg) 0%, #FFE4EF 100%);
    text-align: center;
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--color-primary-dark);
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 30px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact-card {
    background: white;
    padding: 40px 30px;
    border-radius: var(--radius-lg);
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
  }

  .contact-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .contact-icon {
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .contact-card h4 {
    font-size: 1.3rem;
    color: var(--color-primary-dark);
    margin-bottom: 12px;
  }

  .contact-value {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .contact-sub {
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .map-section {
    background: var(--color-bg);
  }

  .map-note {
    text-align: center;
    margin-top: 16px;
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  .cta-section {
    background: linear-gradient(135deg, var(--color-primary-dark), #C4177A);
    text-align: center;
    color: white;
  }

  .cta-section h2 {
    color: white;
    font-size: 2.2rem;
    margin-bottom: 12px;
  }

  .cta-section p {
    font-size: 1rem;
    margin-bottom: 24px;
    opacity: 0.9;
  }

  .cta-section .btn-primary {
    background: white;
    color: var(--color-primary-dark);
  }
</style>
