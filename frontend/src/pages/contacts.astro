---
import Layout from '../layouts/Layout.astro';
import ContactsInfo from '../components/ContactsInfo.jsx';
---

<Layout title="Контакты" description="Контактная информация маникюрного салона GLAM nails">
  <section class="page-header">
    <div class="container">
      <h1>Контакты</h1>
      <p>Свяжитесь с нами любым удобным способом</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ContactsInfo client:load />
    </div>
  </section>

  <section class="section map-section">
    <div class="container">
      <div class="map-placeholder">
        <div class="map-content">
          <span class="map-icon">🗺️</span>
          <p>Мы находимся в центре города</p>
          <p class="map-address">ул. Красивая, 15</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <h2>Ждём вас в гости!</h2>
      <p>Запишитесь онлайн и мы подготовим всё для вашего визита</p>
      <a href="/booking" class="btn btn-primary">Записаться онлайн</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 140px 24px 60px;
    background: linear-gradient(135deg, var(--color-bg) 0%, #FFE4EF 100%);
    text-align: center;
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--color-primary-dark);
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  .map-section {
    background: var(--color-bg);
  }

  .map-placeholder {
    max-width: 1100px;
    margin: 0 auto;
    aspect-ratio: 16/7;
    background: linear-gradient(135deg, #FFE4EF, var(--color-bg));
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
  }

  .map-content {
    text-align: center;
    color: var(--color-primary-dark);
  }

  .map-icon {
    font-size: 4rem;
    margin-bottom: 16px;
    display: block;
  }

  .map-content p {
    font-size: 1.1rem;
    margin-bottom: 8px;
  }

  .map-address {
    font-size: 1.4rem;
    font-weight: 600;
    font-family: var(--font-heading);
  }

  .cta-section {
    background: linear-gradient(135deg, var(--color-primary-dark), #C4177A);
    text-align: center;
    color: white;
  }

  .cta-section h2 {
    color: white;
    font-size: 2.2rem;
    margin-bottom: 12px;
  }

  .cta-section p {
    font-size: 1rem;
    margin-bottom: 24px;
    opacity: 0.9;
  }

  .cta-section .btn-primary {
    background: white;
    color: var(--color-primary-dark);
  }
</style>
